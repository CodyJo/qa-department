          "refId": "B",
          "namespace": "AWS/S3",
          "metricName": "NumberOfObjects",
          "statistics": ["Average"],
          "dimensions": { "BucketName": ["thenewbeautifulme-site"], "StorageType": ["AllStorageTypes"] },
