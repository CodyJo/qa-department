{
  "uid": "breakpoint-projects",
  "title": "BreakPoint Labs — Projects Overview",
  "tags": ["breakpoint", "aws", "projects"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "custom",
        "current": { "text": "us-west-2", "value": "us-west-2" },
        "options": [
          { "text": "us-west-2", "value": "us-west-2", "selected": true },
          { "text": "us-east-1", "value": "us-east-1", "selected": false }
        ],
        "query": "us-west-2,us-east-1"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "The New Beautiful Me",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Lambda Invocations & Errors",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "spanNulls": true },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e74c3c", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/Lambda",
          "metricName": "Invocations",
          "statistics": ["Sum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "300",
          "region": "$region",
          "label": "Invocations"
        },
        {
          "refId": "B",
          "namespace": "AWS/Lambda",
          "metricName": "Errors",
          "statistics": ["Sum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "300",
          "region": "$region",
          "label": "Errors"
        },
        {
          "refId": "C",
          "namespace": "AWS/Lambda",
          "metricName": "Throttles",
          "statistics": ["Sum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "300",
          "region": "$region",
          "label": "Throttles"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Lambda Duration (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true },
          "color": { "mode": "palette-classic" },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/Lambda",
          "metricName": "Duration",
          "statistics": ["Average"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "300",
          "region": "$region",
          "label": "Avg Duration"
        },
        {
          "refId": "B",
          "namespace": "AWS/Lambda",
          "metricName": "Duration",
          "statistics": ["p99"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "300",
          "region": "$region",
          "label": "p99 Duration"
        },
        {
          "refId": "C",
          "namespace": "AWS/Lambda",
          "metricName": "Duration",
          "statistics": ["Maximum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "300",
          "region": "$region",
          "label": "Max Duration"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Lambda Concurrent Executions",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 1 },
      "datasource": { "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "min": 0, "max": 150,
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/Lambda",
          "metricName": "ConcurrentExecutions",
          "statistics": ["Maximum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "60",
          "region": "$region"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Lambda Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "noValue": "0%"
        }
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/Lambda",
          "metricName": "Errors",
          "statistics": ["Sum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "3600",
          "region": "$region",
          "id": "errors"
        },
        {
          "refId": "B",
          "namespace": "AWS/Lambda",
          "metricName": "Invocations",
          "statistics": ["Sum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "3600",
          "region": "$region",
          "id": "invocations",
          "hide": true
        }
      ],
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": { "left": "errors", "operator": "/", "right": "invocations" },
            "reduce": { "reducer": "lastNotNull" }
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Lambda Memory Used",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 5 },
      "datasource": { "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 180 },
              { "color": "red", "value": 230 }
            ]
          },
          "unit": "decmbytes",
          "max": 256
        }
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/Lambda",
          "metricName": "MaxMemoryUsed",
          "statistics": ["Maximum"],
          "dimensions": { "FunctionName": ["thenewbeautifulme-interpret"] },
          "period": "300",
          "region": "$region"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Gateway — Requests & Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Latency (ms)" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/ApiGateway",
          "metricName": "Count",
          "statistics": ["Sum"],
          "dimensions": { "ApiId": ["thenewbeautifulme-api"] },
          "period": "300",
          "region": "$region",
          "label": "Requests"
        },
        {
          "refId": "B",
          "namespace": "AWS/ApiGateway",
          "metricName": "Latency",
          "statistics": ["Average"],
          "dimensions": { "ApiId": ["thenewbeautifulme-api"] },
          "period": "300",
          "region": "$region",
          "label": "Latency (ms)"
        },
        {
          "refId": "C",
          "namespace": "AWS/ApiGateway",
          "metricName": "4xx",
          "statistics": ["Sum"],
          "dimensions": { "ApiId": ["thenewbeautifulme-api"] },
          "period": "300",
          "region": "$region",
          "label": "4xx"
        },
        {
          "refId": "D",
          "namespace": "AWS/ApiGateway",
          "metricName": "5xx",
          "statistics": ["Sum"],
          "dimensions": { "ApiId": ["thenewbeautifulme-api"] },
          "period": "300",
          "region": "$region",
          "label": "5xx"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DynamoDB — Read/Write Capacity",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1, "stacking": { "mode": "none" } },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/DynamoDB",
          "metricName": "ConsumedReadCapacityUnits",
          "statistics": ["Sum"],
          "dimensions": { "TableName": ["thenewbeautifulme-data"] },
          "period": "300",
          "region": "$region",
          "label": "Read Units"
        },
        {
          "refId": "B",
          "namespace": "AWS/DynamoDB",
          "metricName": "ConsumedWriteCapacityUnits",
          "statistics": ["Sum"],
          "dimensions": { "TableName": ["thenewbeautifulme-data"] },
          "period": "300",
          "region": "$region",
          "label": "Write Units"
        },
        {
          "refId": "C",
          "namespace": "AWS/DynamoDB",
          "metricName": "ThrottledRequests",
          "statistics": ["Sum"],
          "dimensions": { "TableName": ["thenewbeautifulme-data"] },
          "period": "300",
          "region": "$region",
          "label": "Throttled"
        }
      ]
    },
    {
      "type": "timeseries",
