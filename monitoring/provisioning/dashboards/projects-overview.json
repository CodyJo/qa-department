          "metricName": "BytesDownloaded",
          "statistics": ["Sum"],
          "dimensions": { "DistributionId": ["E1I21C6DXV70HC"], "Region": ["Global"] },
          "period": "300",
          "region": "us-east-1",
          "label": "Bytes Downloaded"
        },
        {
          "refId": "C",
          "namespace": "AWS/CloudFront",
          "metricName": "TotalErrorRate",
          "statistics": ["Average"],
          "dimensions": { "DistributionId": ["E1I21C6DXV70HC"], "Region": ["Global"] },
