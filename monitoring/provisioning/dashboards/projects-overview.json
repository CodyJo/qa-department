          { "matcher": { "id": "byName", "options": "Bucket Size" }, "properties": [{ "id": "unit", "value": "decbytes" }] },
          { "matcher": { "id": "byName", "options": "Object Count" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "short" }] }
