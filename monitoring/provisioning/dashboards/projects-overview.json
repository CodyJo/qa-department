          "namespace": "AWS/S3",
          "metricName": "BucketSizeBytes",
          "statistics": ["Average"],
          "dimensions": { "BucketName": ["thenewbeautifulme-site"], "StorageType": ["StandardStorage"] },
          "period": "86400",
          "region": "$region",
